# Active backend: sub2apipay | custom_orchestrator
PAYMENT_ACTIVE_BACKEND=sub2apipay

# Keep false for phased rollout; set true only when switching to custom orchestrator.
PAYMENT_ENABLE_CUSTOM_ORCHESTRATOR=false

# ----- sub2apipay -----
SUB2APIPAY_BASE_URL=https://pay.example.com
SUB2APIPAY_API_TOKEN=
SUB2APIPAY_CREATE_ORDER_PATH=/api/orders
SUB2APIPAY_QUERY_ORDER_PATH=/api/orders/{orderId}
SUB2APIPAY_NOTIFY_URL=https://your-app.example.com/api/payment/webhook?provider=sub2apipay
SUB2APIPAY_RETURN_URL=https://your-app.example.com/pay/result
SUB2APIPAY_WEBHOOK_SECRET=
SUB2APIPAY_TIMEOUT_MS=10000

# ----- custom orchestrator -----
CUSTOM_ORCHESTRATOR_ADAPTER=noop
CUSTOM_ORCHESTRATOR_WEBHOOK_SECRET=
CUSTOM_ORCHESTRATOR_PLACEHOLDER_CHECKOUT_URL=https://example.com/payment-placeholder

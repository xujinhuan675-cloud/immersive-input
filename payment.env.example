# ----- self-orchestrated payment backend (single path) -----
APP_BASE_URL=https://your-app.example.com
PAYMENT_ALLOWED_ORIGINS=tauri://localhost,https://tauri.localhost,http://tauri.localhost
PAYMENT_ADMIN_TOKEN=
CUSTOM_ORCHESTRATOR_ADAPTER=stripe
CUSTOM_ORCHESTRATOR_ENABLED_ADAPTERS=stripe
CUSTOM_ORCHESTRATOR_TIMEOUT_MS=10000
CUSTOM_ORCHESTRATOR_PLACEHOLDER_CHECKOUT_URL=https://example.com/payment-placeholder

# ----- webhook security (borrowed mature pattern: signature + timestamp anti-replay) -----
CUSTOM_ORCHESTRATOR_WEBHOOK_SECRET=
CUSTOM_ORCHESTRATOR_WEBHOOK_SIGNATURE_HEADER=x-custom-orchestrator-signature
CUSTOM_ORCHESTRATOR_WEBHOOK_TIMESTAMP_HEADER=x-custom-orchestrator-timestamp
CUSTOM_ORCHESTRATOR_WEBHOOK_TOLERANCE_SECONDS=300
CUSTOM_ORCHESTRATOR_ENFORCE_WEBHOOK_TIMESTAMP=true

# ----- Stripe real channel (default) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_BASE=https://api.stripe.com
STRIPE_CREATE_CHECKOUT_PATH=/v1/checkout/sessions
STRIPE_RETRIEVE_CHECKOUT_PATH=/v1/checkout/sessions
STRIPE_REFUND_PATH=/v1/refunds
STRIPE_SUCCESS_URL=https://your-app.example.com/pay/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://your-app.example.com/pay/cancel
STRIPE_MODE=payment
STRIPE_PAYMENT_METHOD_TYPES=card
STRIPE_DEFAULT_CURRENCY=USD
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_TIMEOUT_MS=10000
# ----- EasyPay real channel -----
EASYPAY_PID=
EASYPAY_KEY=
EASYPAY_API_BASE=https://pay.example.com
EASYPAY_CREATE_ORDER_PATH=/api/pay/create
EASYPAY_QUERY_ORDER_PATH=/api/pay/query
EASYPAY_REFUND_ORDER_PATH=
EASYPAY_NOTIFY_URL=https://your-app.example.com/api/payment/webhook
EASYPAY_RETURN_URL=https://your-app.example.com/pay/result
EASYPAY_DEFAULT_TYPE=alipay
EASYPAY_SIGN_TYPE=MD5
EASYPAY_TIMEOUT_MS=10000

# ----- Alipay official direct channel -----
# desktop app defaults to browser cashier redirect; set ALIPAY_DESKTOP_MODE=qr only if your app has precreate / face-to-face payment permission
ALIPAY_APP_ID=
# supports file path or raw key content
ALIPAY_PRIVATE_KEY=
# must be Alipay public key, not your app public key
ALIPAY_PUBLIC_KEY=
ALIPAY_DESKTOP_MODE=redirect
ALIPAY_VERIFY_RESPONSE_SIGNATURE=false
ALIPAY_API_BASE=https://openapi.alipay.com/gateway.do
# provider auto-detected; prefer plain webhook URL
ALIPAY_NOTIFY_URL=https://your-app.example.com/api/payment/webhook
ALIPAY_RETURN_URL=https://your-app.example.com/pay/result
ALIPAY_DEFAULT_CURRENCY=CNY
ALIPAY_TIMEOUT_MS=10000

# ----- WeChat Pay official direct channel -----
WXPAY_APP_ID=
WXPAY_MCH_ID=
# supports file path or raw PEM content
WXPAY_PRIVATE_KEY=
WXPAY_CERT_SERIAL=
WXPAY_API_V3_KEY=
WXPAY_PUBLIC_KEY=
WXPAY_PUBLIC_KEY_ID=
WXPAY_API_BASE=https://api.mch.weixin.qq.com
# provider auto-detected from WeChat Pay signature headers
WXPAY_NOTIFY_URL=https://your-app.example.com/api/payment/webhook
WXPAY_RETURN_URL=https://your-app.example.com/
WXPAY_DEFAULT_CURRENCY=CNY
WXPAY_TIMEOUT_MS=10000

# ----- billing -----
# free tier daily quota
BILLING_FREE_DAILY_QUOTA=20
# 1 CNY => how many credits
BILLING_TOPUP_CREDITS_PER_CNY=100
# whether to consume credits after daily quota is exhausted
BILLING_ALLOW_CREDIT_FALLBACK=true
# optional public catalog settings
BILLING_CURRENCY=CNY
BILLING_TOPUP_PRESET_AMOUNTS=29,59,99,199
BILLING_PLAN_PRICE_MEMBERSHIP_BASIC_MONTH=29
BILLING_PLAN_PRICE_MEMBERSHIP_BASIC_YEAR=299
BILLING_PLAN_PRICE_MEMBERSHIP_PRO_MONTH=59
BILLING_PLAN_PRICE_MEMBERSHIP_PRO_YEAR=599
BILLING_PLAN_PRICE_MEMBERSHIP_ENTERPRISE_MONTH=199
BILLING_PLAN_PRICE_MEMBERSHIP_ENTERPRISE_YEAR=1999
